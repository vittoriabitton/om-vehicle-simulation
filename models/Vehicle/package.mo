within ;
package Vehicle "Modular vehicle simulation (OpenModelica, educational)"
  extends Modelica.Icons.Package;

  annotation(
    Documentation(info = "<html>
<p>Generic powertrain models for digital-twin style simulation. No customer-specific
parameters in this public repo.</p>
</html>"),
    version = "0.1.0",
    uses(Modelica));
end Vehicle;
